# 目标仓库路径（必填）
REPO_PATH=/path/to/your/repo
REPO_NAME=your-repo-name

# API 服务端口
API_PORT=4201

# Web 服务端口
WEB_PORT=4200

# LLM 配置
LLM_PROVIDER=deepseek      # deepseek | openai | bailian | local
LLM_API_KEY=
LLM_MODEL=deepseek-chat    # deepseek-chat | gpt-4o | 其他兼容模型
LLM_BASE_URL=https://api.deepseek.com  # DeepSeek 地址；使用 OpenAI 原生则留空

# 告警配置（可选）
ALERT_TYPE=                 # feishu | dingtalk | webhook
ALERT_WEBHOOK=
