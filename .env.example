# 目标仓库路径（必填）
REPO_PATH=/path/to/your/repo
REPO_NAME=your-repo-name

# API 服务端口
API_PORT=4201

# Web 服务端口
WEB_PORT=4200

# LLM 配置
LLM_PROVIDER=deepseek      # deepseek | openai | bailian | local | ollama | custom
LLM_API_KEY=
LLM_MODEL=deepseek-chat    # deepseek-chat | gpt-4o | 其他兼容模型
LLM_BASE_URL=https://api.deepseek.com  # DeepSeek 地址；使用 OpenAI 原生则留空
LLM_RUNTIME_MODE=api       # api | intranet，默认优先使用 API
LLM_TIMEOUT_MS=60000       # API 调用超时（毫秒），默认 60 秒
LLM_MAX_TOKENS=4096        # LLM 最大生成 token 数，默认 4096，避免模型输出被截断

# 内网 Ollama 配置（可选）
INTRANET_OLLAMA_BASE_URL=
INTRANET_OLLAMA_MODELS=["qwen3-vl:32b","deepseek-r1:32b"]
INTRANET_OLLAMA_DEFAULT_MODEL=deepseek-r1:32b
INTRANET_OLLAMA_TIMEOUT_MS=120000  # Ollama 推理超时（毫秒），默认 LLM_TIMEOUT_MS × 2；推理模型建议 120 秒以上

# 告警配置（可选）
ALERT_TYPE=wecom            # wecom | webhook
ALERT_WEBHOOK=
