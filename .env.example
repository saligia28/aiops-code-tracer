# 目标仓库路径（必填）
REPO_PATH=/path/to/your/repo
REPO_NAME=your-repo-name

# API 服务端口
API_PORT=4201

# Web 服务端口
WEB_PORT=4200

# LLM 配置
LLM_PROVIDER=openai        # openai | bailian | local
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_BASE_URL=

# 告警配置（可选）
ALERT_TYPE=                 # feishu | dingtalk | webhook
ALERT_WEBHOOK=
